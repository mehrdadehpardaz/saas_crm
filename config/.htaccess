# config/.htaccess
# جلوگیری کامل از دسترسی مستقیم به این پوشه از طریق مرورگر.
# حتی اگر سرور به هر دلیلی PHP را روی این فایل اجرا نکند و آن را به‌صورت
# متن خام نشان دهد، این قانون از افشای رمز دیتابیس جلوگیری می‌کند.

<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>